<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!--
        Background playback support (#47):
         - FOREGROUND_SERVICE: required to start any foreground service.
         - FOREGROUND_SERVICE_MEDIA_PLAYBACK: required for the "mediaPlayback"
           foreground service type on Android 14+ (API 34).
         - POST_NOTIFICATIONS: required on Android 13+ (API 33) to display the
           media-style notification we attach to the foreground service.
    -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".MuSyncApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MuSync">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.MuSync">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Deep link: https://${inviteLinkHost}/room/{roomId} -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="https"
                    android:host="${inviteLinkHost}"
                    android:pathPrefix="/room/" />
            </intent-filter>
        </activity>

        <!--
            Foreground service that owns the MediaSessionCompat + notification
            for background playback (#47).  Receives Play / Pause / Skip /
            Stop intents from the notification's action buttons and forwards
            them to the running PlayerScreen via MediaPlaybackController.
        -->
        <service
            android:name=".playback.MediaPlaybackService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />

    </application>

</manifest>

