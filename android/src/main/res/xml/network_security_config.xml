<?xml version="1.0" encoding="utf-8"?>
<!--
    Network security configuration.

    Allows cleartext (HTTP) traffic only for the Android emulator's host alias
    (10.0.2.2) and localhost so that local development against the default
    server URL (http://10.0.2.2:3000) works on Android 9+ devices.

    Production builds should point SERVER_URL at an HTTPS endpoint, in which
    case this exception is never exercised.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <!-- Android emulator host alias -->
        <domain includeSubdomains="false">10.0.2.2</domain>
        <!-- Physical device running a local server -->
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>
</network-security-config>
