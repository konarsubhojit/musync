# ── MuSync Server Environment Variables ──────────────────────────────────────

# Server port (default: 3000)
PORT=3000

# ── Upstash Redis (Session State) ─────────────────────────────────────────────
# Obtain these values from your Upstash console: https://console.upstash.com
# When both variables are set the server persists room state in Redis with a
# 4-hour TTL.  If either variable is absent the server falls back to an
# in-memory store (suitable for local development and testing only).

UPSTASH_REDIS_REST_URL=https://<your-instance>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<your-rest-token>

# ── Android App Links (Invite-link domain) ────────────────────────────────────
# Serving the invite-link domain (`https://<host>/room/<id>`) from the same
# host as the Socket.IO API requires the server to expose an Android App
# Links manifest at `/.well-known/assetlinks.json`.  Set both variables below
# to enable that route; leave them unset to disable it (the route returns 404).
#
# ANDROID_APP_PACKAGE_NAME      Application id of the Android app
#                               (matches `applicationId` in android/build.gradle.kts)
# ANDROID_APP_SHA256_FINGERPRINTS
#                               Comma-separated SHA-256 signing-certificate
#                               fingerprints (uppercase hex, colon-separated).
#                               Include both your debug and release fingerprints
#                               if you want App Links to verify for both builds.
#                               Get them with:
#                                 keytool -list -v -keystore <keystore> -alias <alias>

ANDROID_APP_PACKAGE_NAME=com.musync
ANDROID_APP_SHA256_FINGERPRINTS=AA:BB:CC:...,11:22:33:...
# ^^^ For CI-built debug APKs use the SHA-256 fingerprint from the keystore
#     configured via DEBUG_KEYSTORE_BASE64 / DEBUG_KEY_* secrets in GitHub Actions.
#     Release signing is separate; add its fingerprint here alongside the debug one
#     when both build types need App Links verification.
#     Retrieve the fingerprint with:
#       keytool -list -v -keystore debug.jks -alias <alias>
